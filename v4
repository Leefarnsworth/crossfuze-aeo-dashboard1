    </div>
  );
}

function NextCard({ title, text }) {
  return (
    <div className="rounded-[24px] border border-white/10 bg-white/[0.045] p-6 shadow-lg shadow-black/10 backdrop-blur-sm transition-all">
      <div className="text-lg font-semibold tracking-tight">{title}</div>
      <p className="mt-3 text-sm leading-6 text-white/72">{text}</p>
    </div>
